<hibernate-configuration>
	<session-factory>
		<property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
		<property name="hibernate.connection.url">jdbc:mysql://localhost:3306/ormdb</property>
		<property name="hibernate.connection.username">root</property>
		<property name="hibernate.connection.password">root@39</property>
		<property name="hibernate.show_sql">true</property>
		<property name="hibernate.current_session_context_class">thread</property>
		<property name="hibernate.query.factory_class">org.hibernate.hql.classic.ClassicQueryTranslatorFactory
		</property>
		<property name="hibernate.show_sql">true</property>
		<property name="hibernate.format_sql">true</property>
		<property name="hibernate.hbm2ddl.auto">update</property>
		<property name="hibernate.cache.use_second_level_cache">true</property>
		<property name="hibernate.cache.region.factory_class">org.hibernate.cache.jcache.internal.JCacheRegionFactory
		</property>
		<property name="hibernate.javax.cache.provider">org.ehcache.jsr107.EhcacheCachingProvider
		</property>
		<mapping class="com.mphasis.firsthibernate.model.Contact" />
		<mapping class="com.mphasis.firsthibernate.model.User" />
		<mapping class="com.mphasis.firsthibernate.model.Locker" />
		<mapping class="com.mphasis.firsthibernate.model.Customer" />
		<mapping class="com.mphasis.firsthibernate.model.Employee" />
		<mapping class="com.mphasis.firsthibernate.model.Department" />
		<mapping class="com.mphasis.firsthibernate.model.BlogPost" />
		<mapping class="com.mphasis.firsthibernate.model.Comment" />
		<mapping class="com.mphasis.firsthibernate.model.Student" />
		<mapping class="com.mphasis.firsthibernate.model.Course" />
		<mapping class="com.mphasis.firsthibernate.model.Vehicle" />
		<mapping class="com.mphasis.firsthibernate.model.TwoWheeler" />
		<mapping class="com.mphasis.firsthibernate.model.FourWheeler" />
		<mapping class="com.mphasis.firsthibernate.model.Account" />
		<mapping
			class="com.mphasis.firsthibernate.model.CreditAccount" />
		<mapping class="com.mphasis.firsthibernate.model.DebitAccount" />
	</session-factory>
</hibernate-configuration>